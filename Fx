#!/bin/bash
#
# fxTunnel Installer & Service Manager
#
# Manages fxTunnel as long-running, auto-restarting processes WITHOUT
# depending on systemd/systemctl. Persistence is handled by supervisord,
# which is itself started at boot via cron @reboot - this works on any
# Linux environment (VPS, containers, minimal images) regardless of
# whether an init system with systemd is present.
#
# Requires root (sudo).
#

set -uo pipefail

# ---------------------------------------------------------------------------
# Colors and display helpers
# ---------------------------------------------------------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m'
BOLD='\033[1m'

print_section() {
    echo ""
    echo -e "${PURPLE}══════════════════════════════════════════════════════════════${NC}"
    echo -e "${YELLOW}${BOLD}  $1${NC}"
    echo -e "${PURPLE}══════════════════════════════════════════════════════════════${NC}"
    echo ""
}
print_success() { echo -e "${GREEN}✓ $1${NC}"; }
print_error()   { echo -e "${RED}✗ $1${NC}"; }
print_info()    { echo -e "${BLUE}ℹ $1${NC}"; }
print_warning() { echo -e "${YELLOW}⚠ $1${NC}"; }

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
FXTUNNEL_BIN=""
SUPERVISOR_CONF_DIR="/etc/supervisor/conf.d"
SUPERVISOR_MAIN_CONF="/etc/supervisor/supervisord.conf"
STATE_DIR="/etc/fxtunnel-manager/state"     # one JSON-ish file per service: port + token
LOG_DIR="/var/log/fxtunnel"
SERVICE_PREFIX="fxtunnel-"

mkdir -p "$STATE_DIR" "$LOG_DIR" 2>/dev/null

# ---------------------------------------------------------------------------
# Core helpers
# ---------------------------------------------------------------------------

check_root() {
    if [[ $EUID -ne 0 ]]; then
        print_error "This script must be run as root!"
        print_info "Please run: sudo bash $0"
        exit 1
    fi
}

find_fxtunnel() {
    if [ -x "/usr/local/bin/fxtunnel" ]; then
        FXTUNNEL_BIN="/usr/local/bin/fxtunnel"
    elif [ -x "/root/.local/bin/fxtunnel" ]; then
        FXTUNNEL_BIN="/root/.local/bin/fxtunnel"
    elif command -v fxtunnel &>/dev/null; then
        FXTUNNEL_BIN=$(command -v fxtunnel)
    else
        FXTUNNEL_BIN=""
    fi
}

require_fxtunnel_or_return() {
    find_fxtunnel
    if [ -z "$FXTUNNEL_BIN" ]; then
        print_error "fxTunnel not installed!"
        print_info "Please install fxTunnel first (Option 1)"
        sleep 2
        return 1
    fi
    return 0
}

# Checks that supervisord is installed, and offers to install it if missing.
# FIX: replaces the previous hard dependency on systemd/systemctl for
# process persistence. supervisord is chosen because it provides real
# restart policies, centralized logs, and a queryable status - unlike a
# hand-rolled bash retry loop - while not requiring any init system.
require_supervisor_or_install() {
    if command -v supervisord &>/dev/null; then
        return 0
    fi

    print_warning "supervisord is not installed (needed to keep tunnels alive)."
    if ! confirm "Install supervisor now via the system package manager?"; then
        return 1
    fi

    if command -v apt-get &>/dev/null; then
        apt-get update -y >>"$LOG_DIR/install.log" 2>&1
        apt-get install -y supervisor >>"$LOG_DIR/install.log" 2>&1
    elif command -v yum &>/dev/null; then
        yum install -y supervisor >>"$LOG_DIR/install.log" 2>&1
    elif command -v apk &>/dev/null; then
        apk add --no-cache supervisor >>"$LOG_DIR/install.log" 2>&1
    elif command -v pip3 &>/dev/null; then
        pip3 install supervisor >>"$LOG_DIR/install.log" 2>&1
    else
        print_error "No supported package manager found (apt/yum/apk/pip3)."
        print_info "Install supervisor manually, then re-run this script."
        return 1
    fi

    if ! command -v supervisord &>/dev/null; then
        print_error "supervisord installation failed. See $LOG_DIR/install.log"
        return 1
    fi

    mkdir -p "$SUPERVISOR_CONF_DIR"

    # Ensure the main supervisord.conf includes our conf.d directory.
    # A minimal working config is created if none exists (e.g. pip install).
    if [ ! -f "$SUPERVISOR_MAIN_CONF" ]; then
        mkdir -p "$(dirname "$SUPERVISOR_MAIN_CONF")"
        cat > "$SUPERVISOR_MAIN_CONF" <<EOF
[unix_http_server]
file=/var/run/supervisor.sock
chmod=0700

[supervisord]
logfile=${LOG_DIR}/supervisord.log
pidfile=/var/run/supervisord.pid
childlogdir=${LOG_DIR}

[rpcinterface:supervisor]
supervisor.rpcinterface_factory = supervisor.rpcinterface:make_main_rpcinterface

[supervisorctl]
serverurl=unix:///var/run/supervisor.sock

[include]
files = ${SUPERVISOR_CONF_DIR}/*.conf
EOF
    elif ! grep -q "$SUPERVISOR_CONF_DIR" "$SUPERVISOR_MAIN_CONF" 2>/dev/null; then
        printf '\n[include]\nfiles = %s/*.conf\n' "$SUPERVISOR_CONF_DIR" >> "$SUPERVISOR_MAIN_CONF"
    fi

    print_success "supervisor installed and configured."
    ensure_supervisord_running
    ensure_boot_persistence
    return 0
}

# Starts the supervisord daemon if it is not already running.
ensure_supervisord_running() {
    if pgrep -f "supervisord -c ${SUPERVISOR_MAIN_CONF}" >/dev/null 2>&1 || pgrep -x supervisord >/dev/null 2>&1; then
        return 0
    fi
    print_info "Starting supervisord..."
    supervisord -c "$SUPERVISOR_MAIN_CONF" >>"$LOG_DIR/install.log" 2>&1
    sleep 1
    if pgrep -x supervisord >/dev/null 2>&1; then
        print_success "supervisord is running."
    else
        print_error "supervisord failed to start. See $LOG_DIR/install.log"
        return 1
    fi
}

# Ensures supervisord itself restarts after a reboot, WITHOUT using systemd.
# Uses a root crontab @reboot entry, which is honored by cron on virtually
# every Linux distribution (including systemd-less containers, as long as a
# cron daemon is present/installed).
# FIX (was the whole point of this rewrite): previously the only persistence
# mechanism across reboots was a systemd unit (WantedBy=multi-user.target).
ensure_boot_persistence() {
    if ! command -v crontab &>/dev/null; then
        print_warning "No 'cron' found. supervisord (and therefore your tunnels) will NOT restart automatically after a reboot."
        if command -v apt-get &>/dev/null; then
            print_info "Install it with: sudo apt-get install -y cron"
        fi
        return 1
    fi

    local reboot_cmd="@reboot /usr/bin/env supervisord -c ${SUPERVISOR_MAIN_CONF} >> ${LOG_DIR}/supervisord-boot.log 2>&1"
    local current_crontab
    current_crontab=$(crontab -l 2>/dev/null || true)

    if echo "$current_crontab" | grep -qF "supervisord -c ${SUPERVISOR_MAIN_CONF}"; then
        return 0
    fi

    { echo "$current_crontab"; echo "$reboot_cmd"; } | grep -v '^$' | crontab -
    print_success "Added a cron @reboot entry so supervisord (and your tunnels) survive reboots."
}

ask() {
    local question="$1" default="${2:-}" answer
    if [[ -n "$default" ]]; then
        read -rp "$(echo -e "${BOLD}${question}${NC} [${default}]: ")" answer
        echo "${answer:-$default}"
    else
        read -rp "$(echo -e "${BOLD}${question}${NC}: ")" answer
        echo "$answer"
    fi
}

confirm() {
    local question="$1" answer
    read -rp "$(echo -e "${BOLD}${question}${NC} [y/N]: ")" answer
    [[ "$answer" =~ ^([yY][eE][sS]|[yY])$ ]]
}

# Reads a secret without echoing it to the terminal.
ask_secret() {
    local question="$1" answer
    read -rsp "$(echo -e "${BOLD}${question}${NC}: ")" answer
    echo "" >&2
    echo "$answer"
}

# ---------------------------------------------------------------------------
# Service name / state helpers
# ---------------------------------------------------------------------------

# All service identifiers are of the form fxtunnel-<name>.
# supervisord program name == identifier (no ".service" suffix, unlike systemd units).

state_file_for() { echo "${STATE_DIR}/$1.env"; }
conf_file_for()  { echo "${SUPERVISOR_CONF_DIR}/$1.conf"; }
log_file_for()   { echo "${LOG_DIR}/$1.log"; }

# Persists port/token OUTSIDE the process command line.
# FIX (Critical - token exposure): the previous script embedded the token
# directly in ExecStart=..., which is visible to any local user via
# `ps aux` / `/proc/<pid>/cmdline`, and in `systemctl cat`. Storing it in a
# root-only-readable file and injecting it as an environment variable in
# supervisor's config keeps it out of the process argument list.
save_state() {
    local name="$1" port="$2" token="$3"
    local f; f=$(state_file_for "$name")
    umask 077
    printf 'PORT=%s\nTOKEN=%s\n' "$port" "$token" > "$f"
    chmod 600 "$f"
}

load_state_port()  { local f; f=$(state_file_for "$1"); [ -f "$f" ] && grep '^PORT=' "$f" | cut -d= -f2-; }
load_state_token() { local f; f=$(state_file_for "$1"); [ -f "$f" ] && grep '^TOKEN=' "$f" | cut -d= -f2-; }

# Generates (or overwrites) a supervisor program config for one tunnel.
# FIX (code quality): this single function replaces five near-identical
# heredoc blocks duplicated across the original script's
# create/edit/fix/bulk-create functions.
write_supervisor_conf() {
    local name="$1" port="$2" token="$3"
    local conf; conf=$(conf_file_for "$name")
    local log;  log=$(log_file_for "$name")

    cat > "$conf" <<EOF
[program:${name}]
command=${FXTUNNEL_BIN} tcp ${port} -t %(ENV_FXTUNNEL_TOKEN)s
directory=/root
autostart=true
autorestart=true
startretries=10
startsecs=3
stopasgroup=true
killasgroup=true
stopsignal=TERM
environment=HOME="/root",PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/root/.local/bin",FXTUNNEL_TOKEN="${token}"
stdout_logfile=${log}
stdout_logfile_maxbytes=5MB
stdout_logfile_backups=3
stderr_logfile=${log}
stderr_logfile_maxbytes=5MB
stderr_logfile_backups=3
EOF
    chmod 600 "$conf"
    save_state "$name" "$port" "$token"
}

# Returns the bare list of fxtunnel-managed program names known to supervisor.
list_service_names() {
    supervisorctl -c "$SUPERVISOR_MAIN_CONF" status 2>/dev/null \
        | awk '{print $1}' | grep "^${SERVICE_PREFIX}" || true
}

service_status() {
    # Prints one of: RUNNING, STOPPED, FATAL, STARTING, BACKOFF, EXITED, UNKNOWN
    supervisorctl -c "$SUPERVISOR_MAIN_CONF" status "$1" 2>/dev/null | awk '{print $2}'
}

reload_supervisor() {
    supervisorctl -c "$SUPERVISOR_MAIN_CONF" reread >/dev/null 2>&1
    supervisorctl -c "$SUPERVISOR_MAIN_CONF" update >/dev/null 2>&1
}

# ---------------------------------------------------------------------------
# Install fxTunnel
# ---------------------------------------------------------------------------
install_fxtunnel() {
    print_section "Installing fxTunnel"

    find_fxtunnel
    if [ -n "$FXTUNNEL_BIN" ]; then
        print_info "fxTunnel is already installed at: $FXTUNNEL_BIN"
        if ! confirm "Do you want to reinstall?"; then
            require_supervisor_or_install
            return
        fi
        rm -f "$FXTUNNEL_BIN"
    fi

    print_info "Downloading and installing fxTunnel..."

    # FIX (High - integrity): the previous script piped curl straight into
    # sh with no verification and no separate exit-code check on curl
    # itself (a pipeline's $? reflects the LAST command, i.e. sh, not
    # curl - so a failed download could still report "success" if sh got
    # an empty stream and exited 0). We now download to a temp file first,
    # check curl's own exit code, and only then execute it.
    local installer_tmp; installer_tmp=$(mktemp)
    if ! curl -fsSL https://fxtun.dev/install.sh -o "$installer_tmp"; then
        print_error "Failed to download the installer (network error or URL unreachable)."
        rm -f "$installer_tmp"
        echo ""; read -rp "Press Enter to continue..."; return
    fi

    print_warning "No official checksum/signature is published for this installer as far as could be verified; it will run with root privileges."
    if ! confirm "Proceed with running the downloaded installer?"; then
        rm -f "$installer_tmp"
        return
    fi

    sh "$installer_tmp"
    local install_rc=$?
    rm -f "$installer_tmp"

    if [ $install_rc -ne 0 ]; then
        print_error "fxTunnel installer exited with an error (code $install_rc)."
        echo ""; read -rp "Press Enter to continue..."; return
    fi

    find_fxtunnel
    if [ -z "$FXTUNNEL_BIN" ] && [ -f "/root/.local/bin/fxtunnel" ]; then
        FXTUNNEL_BIN="/root/.local/bin/fxtunnel"
        chmod +x "$FXTUNNEL_BIN"
    fi

    if [ -z "$FXTUNNEL_BIN" ]; then
        print_error "Installation finished but the fxtunnel binary could not be located."
        echo ""; read -rp "Press Enter to continue..."; return
    fi

    print_success "fxTunnel installed at: $FXTUNNEL_BIN"

    print_section "Configuring PATH Environment"
    if ! grep -q "/root/.local/bin" /root/.bashrc 2>/dev/null; then
        echo 'export PATH=$PATH:/root/.local/bin' >> /root/.bashrc
        print_success "Added to /root/.bashrc"
    fi
    if ! grep -q "/root/.local/bin" /etc/profile 2>/dev/null; then
        echo 'export PATH=$PATH:/root/.local/bin' >> /etc/profile
    fi
    export PATH=$PATH:/root/.local/bin

    if [ -x "$FXTUNNEL_BIN" ]; then
        local version; version=$("$FXTUNNEL_BIN" --version 2>&1 || echo "version check skipped")
        print_info "Version: $version"
    else
        chmod +x "$FXTUNNEL_BIN" 2>/dev/null || true
    fi

    require_supervisor_or_install

    echo ""; read -rp "Press Enter to continue..."
}

# ---------------------------------------------------------------------------
# Test connection (no persistent service created)
# ---------------------------------------------------------------------------
test_fxtunnel() {
    print_section "Test fxTunnel Connection"
    require_fxtunnel_or_return || return

    local test_token; test_token=$(ask_secret "Enter token to test (input hidden)")
    if [ -z "$test_token" ]; then
        print_error "Token cannot be empty!"
        return
    fi

    local test_port; test_port=$(ask "Enter port to test" "22")
    if ! [[ "$test_port" =~ ^[0-9]+$ ]] || (( 10#$test_port < 1 || 10#$test_port > 65535 )); then
        print_error "Invalid port."
        return
    fi

    print_info "Testing connection for 8 seconds..."
    FXTUNNEL_TOKEN="$test_token" timeout 10 "$FXTUNNEL_BIN" tcp "$test_port" -t "$test_token" &>/dev/null &
    local pid=$!
    sleep 8

    if kill -0 "$pid" 2>/dev/null; then
        print_success "Connection test successful! fxTunnel is running."
        kill "$pid" 2>/dev/null
    else
        print_warning "Process exited before the test window ended - check your token/port."
    fi

    echo ""; read -rp "Press Enter to continue..."
}

# ---------------------------------------------------------------------------
# List services
# ---------------------------------------------------------------------------
list_services() {
    print_section "Existing fxTunnel Services"

    local names; names=$(list_service_names)
    if [ -z "$names" ]; then
        print_info "No fxTunnel services found"
        echo ""; read -rp "Press Enter to continue..."; return
    fi

    echo -e "${CYAN}${BOLD}Current services:${NC}"
    echo -e "${WHITE}────────────────────────────────────────────────────────────${NC}"

    while IFS= read -r name; do
        [ -z "$name" ] && continue
        local status; status=$(service_status "$name")
        local port; port=$(load_state_port "$name"); [ -z "$port" ] && port="N/A"
        local token; token=$(load_state_token "$name")

        local status_color
        case "$status" in
            RUNNING) status_color="${GREEN}● RUNNING${NC}" ;;
            FATAL)   status_color="${RED}● FATAL${NC}" ;;
            BACKOFF) status_color="${YELLOW}● BACKOFF (retrying)${NC}" ;;
            STARTING) status_color="${YELLOW}● STARTING${NC}" ;;
            STOPPED|EXITED) status_color="${YELLOW}● STOPPED${NC}" ;;
            *) status_color="${RED}● ${status:-UNKNOWN}${NC}" ;;
        esac

        echo -e "  ${YELLOW}Service:${NC} $name"
        echo -e "  ${YELLOW}Status:${NC}  $status_color"
        echo -e "  ${YELLOW}Port:${NC}    $port"
        echo -e "  ${YELLOW}Token:${NC}   ${token:0:8}$( [ -n "$token" ] && echo '...' )"
        echo -e "${WHITE}────────────────────────────────────────────────────────────${NC}"
    done <<< "$names"

    echo ""; read -rp "Press Enter to continue..."
}

# ---------------------------------------------------------------------------
# Create new service
# ---------------------------------------------------------------------------
create_service() {
    print_section "Create New fxTunnel Service"
    require_fxtunnel_or_return || return
    require_supervisor_or_install || { print_error "supervisor is required to create a persistent service."; return; }
    ensure_supervisord_running

    local service_name
    while true; do
        service_name=$(ask "Enter service name (e.g., ssh-tunnel)" "")
        if [[ -z "$service_name" ]]; then
            print_error "Service name cannot be empty"
        elif [[ ! "$service_name" =~ ^[a-zA-Z0-9_-]+$ ]]; then
            print_error "Service name can only contain letters, numbers, hyphens and underscores"
        elif [ -f "$(conf_file_for "${SERVICE_PREFIX}${service_name}")" ]; then
            print_error "Service name already exists! Please choose another name."
        else
            break
        fi
    done

    local port
    while true; do
        port=$(ask "Enter port number to tunnel" "22")
        if [[ "$port" =~ ^[0-9]+$ ]] && (( 10#$port >= 1 && 10#$port <= 65535 )); then
            break
        fi
        print_error "Invalid port number! Please enter a number between 1-65535"
    done

    local token
    while true; do
        token=$(ask_secret "Enter your fxTunnel token (input hidden)")
        [[ -z "$token" ]] && print_error "Token cannot be empty" || break
    done

    local full_name="${SERVICE_PREFIX}${service_name}"

    print_info "Creating service: $full_name"
    print_info "Binary: $FXTUNNEL_BIN"
    print_info "Port: $port"

    write_supervisor_conf "$full_name" "$port" "$token"
    reload_supervisor
    supervisorctl -c "$SUPERVISOR_MAIN_CONF" start "$full_name" >/dev/null 2>&1

    sleep 3
    local status; status=$(service_status "$full_name")

    if [ "$status" = "RUNNING" ]; then
        print_success "Service created and running successfully! 🚀"
        echo -e "  ${YELLOW}Name:${NC}   $full_name"
        echo -e "  ${YELLOW}Port:${NC}   $port"
        echo -e "  ${YELLOW}Status:${NC} ${GREEN}RUNNING ✓${NC}"
        echo -e "  ${YELLOW}Command:${NC} supervisorctl status $full_name"
    else
        print_warning "Service status: ${status:-UNKNOWN}"
        print_info "Recent log output:"
        tail -n 15 "$(log_file_for "$full_name")" 2>/dev/null
        print_info "Use Option 10 to attempt a repair."
    fi

    echo ""; read -rp "Press Enter to continue..."
}

# ---------------------------------------------------------------------------
# Edit existing service
# ---------------------------------------------------------------------------
select_service() {
    # Prints the chosen service name to stdout, or nothing if cancelled/invalid.
    local names; names=$(list_service_names)
    if [ -z "$names" ]; then
        print_error "No fxTunnel services found!" >&2
        return 1
    fi

    echo -e "${CYAN}Available services:${NC}" >&2
    echo "" >&2
    local i=1
    local arr=()
    while IFS= read -r n; do
        [ -z "$n" ] && continue
        local st; st=$(service_status "$n")
        echo -e "  ${YELLOW}${i})${NC} $n (${st})" >&2
        arr+=("$n"); ((i++))
    done <<< "$names"

    echo "" >&2
    local sel; read -rp "$(echo -e "Select service (1-${#arr[@]}): ")" sel
    if [[ ! "$sel" =~ ^[0-9]+$ ]] || [ "$sel" -lt 1 ] || [ "$sel" -gt "${#arr[@]}" ]; then
        print_error "Invalid selection!" >&2
        return 1
    fi
    echo "${arr[$((sel-1))]}"
}

edit_service() {
    print_section "Edit fxTunnel Service"
    local selected; selected=$(select_service) || { sleep 2; return; }

    find_fxtunnel
    local current_port; current_port=$(load_state_port "$selected")
    local current_token; current_token=$(load_state_token "$selected")

    echo -e "${CYAN}Current configuration:${NC}"
    echo -e "  Port: ${YELLOW}$current_port${NC}"
    echo -e "  Token: ${YELLOW}${current_token:0:8}...${NC}"
    echo ""

    local new_port; new_port=$(ask "Enter new port number (leave blank to keep)" "$current_port")
    if ! [[ "$new_port" =~ ^[0-9]+$ ]] || (( 10#$new_port < 1 || 10#$new_port > 65535 )); then
        print_error "Invalid port, keeping the previous one."
        new_port="$current_port"
    fi

    local new_token
    new_token=$(ask_secret "Enter new token (leave blank to keep current, input hidden)")
    [ -z "$new_token" ] && new_token="$current_token"

    supervisorctl -c "$SUPERVISOR_MAIN_CONF" stop "$selected" >/dev/null 2>&1

    write_supervisor_conf "$selected" "$new_port" "$new_token"
    reload_supervisor
    supervisorctl -c "$SUPERVISOR_MAIN_CONF" start "$selected" >/dev/null 2>&1

    sleep 3
    if [ "$(service_status "$selected")" = "RUNNING" ]; then
        print_success "Service updated and running! ✓"
    else
        print_warning "Service updated but may not be running."
        tail -n 15 "$(log_file_for "$selected")" 2>/dev/null
    fi

    echo ""; read -rp "Press Enter to continue..."
}

# ---------------------------------------------------------------------------
# Delete service
# ---------------------------------------------------------------------------
delete_service() {
    print_section "Delete fxTunnel Service"
    local selected; selected=$(select_service) || { sleep 2; return; }

    echo ""
    if confirm "DELETE $selected? This cannot be undone!"; then
        print_info "Stopping and removing $selected..."
        supervisorctl -c "$SUPERVISOR_MAIN_CONF" stop "$selected" >/dev/null 2>&1
        rm -f "$(conf_file_for "$selected")" "$(state_file_for "$selected")" "$(log_file_for "$selected")"
        reload_supervisor
        print_success "Service deleted permanently! ✓"
    else
        print_info "Deletion cancelled"
    fi

    echo ""; read -rp "Press Enter to continue..."
}

# ---------------------------------------------------------------------------
# View logs
# ---------------------------------------------------------------------------
view_logs() {
    print_section "View fxTunnel Service Logs"
    local selected; selected=$(select_service) || { sleep 2; return; }

    echo ""
    echo -e "${CYAN}${BOLD}Live logs for: ${YELLOW}$selected${NC}"
    echo -e "${PURPLE}Press Ctrl+C to exit log view${NC}"
    echo ""
    sleep 1
    tail -f "$(log_file_for "$selected")"
}

# ---------------------------------------------------------------------------
# Manage service (Start/Stop/Restart/Enable/Disable/Status)
# ---------------------------------------------------------------------------
manage_service() {
    print_section "Service Management"
    local selected; selected=$(select_service) || { sleep 2; return; }

    echo ""
    echo -e "${CYAN}Manage: ${YELLOW}$selected${NC}"
    echo -e "${WHITE}────────────────────────${NC}"
    echo -e "  ${YELLOW}1)${NC} Start"
    echo -e "  ${YELLOW}2)${NC} Stop"
    echo -e "  ${YELLOW}3)${NC} Restart"
    echo -e "  ${YELLOW}4)${NC} Enable autostart"
    echo -e "  ${YELLOW}5)${NC} Disable autostart"
    echo -e "  ${YELLOW}6)${NC} Show status"
    echo ""
    local action; read -rp "Select action (1-6): " action

    case "$action" in
        1)
            supervisorctl -c "$SUPERVISOR_MAIN_CONF" start "$selected" >/dev/null 2>&1
            sleep 2
            [ "$(service_status "$selected")" = "RUNNING" ] && print_success "Started successfully ✓" || print_error "Failed to start"
            ;;
        2)
            supervisorctl -c "$SUPERVISOR_MAIN_CONF" stop "$selected" >/dev/null 2>&1
            print_success "Stopped ✓"
            ;;
        3)
            supervisorctl -c "$SUPERVISOR_MAIN_CONF" restart "$selected" >/dev/null 2>&1
            sleep 2
            [ "$(service_status "$selected")" = "RUNNING" ] && print_success "Restarted successfully ✓" || print_error "Failed to restart"
            ;;
        4)
            sed -i 's/^autostart=false/autostart=true/' "$(conf_file_for "$selected")" 2>/dev/null
            reload_supervisor
            print_success "Autostart enabled ✓"
            ;;
        5)
            sed -i 's/^autostart=true/autostart=false/' "$(conf_file_for "$selected")" 2>/dev/null
            reload_supervisor
            print_success "Autostart disabled ✓"
            ;;
        6)
            supervisorctl -c "$SUPERVISOR_MAIN_CONF" status "$selected"
            ;;
        *)
            print_error "Invalid action!"
            ;;
    esac

    echo ""; read -rp "Press Enter to continue..."
}

# ---------------------------------------------------------------------------
