# ---------------------------------------------------------------------------
# Bulk create
# ---------------------------------------------------------------------------
create_bulk_services() {
    print_section "Create Multiple Services (Bulk)"
    require_fxtunnel_or_return || return
    require_supervisor_or_install || return
    ensure_supervisord_running

    local token; token=$(ask_secret "Enter token for all services (input hidden)")
    [ -z "$token" ] && { print_error "Token cannot be empty!"; return; }

    local start_port end_port
    start_port=$(ask "Enter starting port number" "")
    end_port=$(ask "Enter ending port number" "")

    if ! [[ "$start_port" =~ ^[0-9]+$ ]] || ! [[ "$end_port" =~ ^[0-9]+$ ]]; then
        print_error "Ports must be numbers!"; return
    fi
    if (( 10#$start_port < 1 || 10#$end_port > 65535 || 10#$start_port > 10#$end_port )); then
        print_error "Invalid port range!"; return
    fi
    if (( 10#$end_port - 10#$start_port > 200 )); then
        print_error "Range too large (max 200 ports at once) to avoid overwhelming the host."; return
    fi

    local base_name; base_name=$(ask "Enter base service name" "tunnel")

    local total=$((end_port - start_port + 1))
    echo ""; echo -e "${CYAN}Creating $total services from port $start_port to $end_port...${NC}"; echo ""

    local success_count=0 fail_count=0
    for port in $(seq "$start_port" "$end_port"); do
        local full_name="${SERVICE_PREFIX}${base_name}-${port}"
        write_supervisor_conf "$full_name" "$port" "$token"
    done

    reload_supervisor
    sleep 2

    for port in $(seq "$start_port" "$end_port"); do
        local full_name="${SERVICE_PREFIX}${base_name}-${port}"
        supervisorctl -c "$SUPERVISOR_MAIN_CONF" start "$full_name" >/dev/null 2>&1
    done

    sleep 3

    for port in $(seq "$start_port" "$end_port"); do
        local full_name="${SERVICE_PREFIX}${base_name}-${port}"
        if [ "$(service_status "$full_name")" = "RUNNING" ]; then
            echo -e "  ${GREEN}✓${NC} $full_name (Port: $port) - RUNNING"
            ((success_count++))
        else
            echo -e "  ${RED}✗${NC} $full_name (Port: $port) - Check logs"
            ((fail_count++))
        fi
    done

    echo ""
    echo -e "${GREEN}${BOLD}Success: $success_count services${NC}"
    if [ "$fail_count" -gt 0 ]; then
        echo -e "${RED}${BOLD}Failed: $fail_count services${NC}"
        echo -e "${CYAN}Use Option 10 to fix failed services${NC}"
    fi

    echo ""; read -rp "Press Enter to continue..."
}

# ---------------------------------------------------------------------------
# Fix / repair services
# ---------------------------------------------------------------------------
fix_all_services() {
    print_section "Fix All fxTunnel Services"
    require_fxtunnel_or_return || return
    require_supervisor_or_install || return
    ensure_supervisord_running

    local names; names=$(list_service_names)
    if [ -z "$names" ]; then
        print_error "No fxTunnel services found to fix!"
        sleep 2; return
    fi

    print_info "Rewriting configs with the current binary path and restarting..."
    echo ""

    while IFS= read -r name; do
        [ -z "$name" ] && continue
        print_info "Processing: $name"

        local port; port=$(load_state_port "$name"); [ -z "$port" ] && port=22
        local token; token=$(load_state_token "$name")

        if [ -z "$token" ]; then
            print_error "  No stored token found for $name (state file missing) - skipping. Recreate it with Option 2."
            continue
        fi

        supervisorctl -c "$SUPERVISOR_MAIN_CONF" stop "$name" >/dev/null 2>&1
        write_supervisor_conf "$name" "$port" "$token"
        reload_supervisor
        supervisorctl -c "$SUPERVISOR_MAIN_CONF" start "$name" >/dev/null 2>&1

        sleep 2
        local status; status=$(service_status "$name")
        if [ "$status" = "RUNNING" ]; then
            echo -e "  ${GREEN}✓ $name - RUNNING${NC}"
        else
            echo -e "  ${RED}✗ $name - ${status:-UNKNOWN}${NC}"
            print_info "  Last log lines:"
            tail -n 5 "$(log_file_for "$name")" 2>/dev/null
        fi
        echo ""
    done <<< "$names"

    print_success "All services processed!"
    echo ""; read -rp "Press Enter to continue..."
}

